{
    "openapi": "3.0.0",
    "info": {
        "title": "Tambourine HubSpot Integration API",
        "description": "API for managing contacts and deals synced with HubSpot.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "API Server"
        }
    ],
    "paths": {
        "/associations": {
            "post": {
                "tags": [
                    "Associations"
                ],
                "summary": "Associate a contact with a deal",
                "description": "Links an existing local contact to an existing local deal by creating the association in HubSpot and persisting it locally. Both the contact and deal must already exist in HubSpot (i.e. have a client_id). If either is not found in HubSpot, the operation is rejected.",
                "operationId": "85e870f0ea89a12e117d7df8707e4e81",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateAssociationRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Association created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AssociationResource"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation failed — contact_id or deal_id are missing, non-numeric, or do not exist in the local database",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AssociationValidationErrorResponse"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "HubSpot service error — covers contact/deal not found in HubSpot, authentication failure, rate limit exceeded, connection failure, and request timeout",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Unexpected internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UnexpectedErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/contacts": {
            "post": {
                "tags": [
                    "Contacts"
                ],
                "summary": "Create a new contact",
                "description": "Creates a contact in the local database and syncs it with HubSpot within a single transaction. If the HubSpot sync fails, the database record is rolled back and no contact is persisted.",
                "operationId": "24f7d39ea3f69b1f561ea368af46f5d3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateContactRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Contact created and synced with HubSpot successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ContactResource"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Request validation failed (missing or invalid fields)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationErrorResponse"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "HubSpot service error — covers authentication failure, rate limit exceeded, invalid properties, connection failure, and request timeout",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Unexpected internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UnexpectedErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/deals": {
            "post": {
                "tags": [
                    "Deals"
                ],
                "summary": "Create a new deal",
                "description": "Creates a deal in the local database and syncs it with HubSpot within a single transaction. If the HubSpot sync fails, the database record is rolled back and no deal is persisted.",
                "operationId": "937ee6c11f2995c92f12009d9f3c24b8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateDealRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Deal created and synced with HubSpot successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DealResource"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Request validation failed (missing or invalid fields)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DealValidationErrorResponse"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "HubSpot service error — covers authentication failure, rate limit exceeded, invalid properties, connection failure, and request timeout",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Unexpected internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UnexpectedErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/webhooks/contact-updated": {
            "post": {
                "tags": [
                    "Webhooks"
                ],
                "summary": "Receive a HubSpot contact-updated event",
                "description": "Processes an incoming HubSpot webhook event for a contact update.\n\n**Idempotency:** Each `event_id` is accepted only once. Replaying the same event returns 422.\n\n**Field requirements:** At least one of `email` or `phone` must be provided. Both can be sent together.\n\nOn success, the matching contact (looked up by `contact_id` = HubSpot `client_id`) is updated with the provided fields and `last_client_updated` is set to the current timestamp. The processed event is recorded and the updated contact is returned.",
                "operationId": "a36e40ca96e258d5a1138df76f2ebad1",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/WebhookContactUpdateRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Event processed successfully — returns the updated contact",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ContactResource"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation failed — missing required fields, duplicate event_id, unknown contact_id, duplicate email, or invalid phone format",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/WebhookContactUpdateValidationErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Unexpected internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UnexpectedErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "AssociationResource": {
                "properties": {
                    "data": {
                        "$ref": "#/components/schemas/Association"
                    }
                },
                "type": "object"
            },
            "Association": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "contact_id": {
                        "type": "integer",
                        "example": 5
                    },
                    "deal_id": {
                        "type": "integer",
                        "example": 3
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "ContactResource": {
                "properties": {
                    "data": {
                        "$ref": "#/components/schemas/Contact"
                    }
                },
                "type": "object"
            },
            "Contact": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "first_name": {
                        "type": "string",
                        "example": "John"
                    },
                    "last_name": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    },
                    "phone": {
                        "type": "string",
                        "example": "+1 555 123 4567",
                        "nullable": true
                    },
                    "client_id": {
                        "type": "string",
                        "example": "hs-123"
                    },
                    "client_provider": {
                        "type": "string",
                        "example": "hubspot"
                    },
                    "last_client_updated": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "CreateAssociationRequest": {
                "required": [
                    "contact_id",
                    "deal_id"
                ],
                "properties": {
                    "contact_id": {
                        "description": "ID of an existing local contact",
                        "type": "integer",
                        "example": 5
                    },
                    "deal_id": {
                        "description": "ID of an existing local deal",
                        "type": "integer",
                        "example": 3
                    }
                },
                "type": "object"
            },
            "CreateContactRequest": {
                "required": [
                    "first_name",
                    "last_name",
                    "email"
                ],
                "properties": {
                    "first_name": {
                        "type": "string",
                        "example": "John"
                    },
                    "last_name": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    },
                    "phone": {
                        "type": "string",
                        "example": "+1 555 123 4567",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "CreateDealRequest": {
                "required": [
                    "name",
                    "amount",
                    "pipeline",
                    "stage"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Summer Vacation"
                    },
                    "amount": {
                        "type": "number",
                        "format": "float",
                        "example": 5000,
                        "minimum": 1
                    },
                    "pipeline": {
                        "type": "string",
                        "example": "default"
                    },
                    "stage": {
                        "type": "string",
                        "example": "appointmentscheduled"
                    }
                },
                "type": "object"
            },
            "DealResource": {
                "properties": {
                    "data": {
                        "$ref": "#/components/schemas/Deal"
                    }
                },
                "type": "object"
            },
            "Deal": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Summer Vacation"
                    },
                    "amount": {
                        "type": "number",
                        "format": "float",
                        "example": 5000
                    },
                    "pipeline": {
                        "type": "string",
                        "example": "default"
                    },
                    "stage": {
                        "type": "string",
                        "example": "appointmentscheduled"
                    },
                    "client_id": {
                        "type": "string",
                        "example": "hs-deal-123"
                    },
                    "client_provider": {
                        "type": "string",
                        "example": "hubspot"
                    },
                    "last_client_updated": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "ErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Hubspot Service Error"
                    },
                    "code": {
                        "type": "integer",
                        "example": 503
                    }
                },
                "type": "object"
            },
            "ValidationErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The first_name field is required."
                    },
                    "errors": {
                        "type": "object",
                        "example": {
                            "first_name": [
                                "The first_name field is required."
                            ]
                        }
                    }
                },
                "type": "object"
            },
            "UnexpectedErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Unexpected Error"
                    },
                    "code": {
                        "type": "integer",
                        "example": 500
                    }
                },
                "type": "object"
            },
            "DealValidationErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The name field is required."
                    },
                    "errors": {
                        "type": "object",
                        "example": {
                            "name": [
                                "The name field is required."
                            ],
                            "amount": [
                                "The amount field is required."
                            ]
                        }
                    }
                },
                "type": "object"
            },
            "AssociationValidationErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The contact id field is required."
                    },
                    "errors": {
                        "type": "object",
                        "example": {
                            "contact_id": [
                                "The selected contact id is invalid."
                            ],
                            "deal_id": [
                                "The selected deal id is invalid."
                            ]
                        }
                    }
                },
                "type": "object"
            },
            "WebhookContactUpdateValidationErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The email field is required when phone is not present."
                    },
                    "errors": {
                        "type": "object",
                        "example": {
                            "email": [
                                "The email field is required when phone is not present."
                            ],
                            "phone": [
                                "The phone field is required when email is not present."
                            ]
                        }
                    }
                },
                "type": "object"
            },
            "WebhookContactUpdateRequest": {
                "required": [
                    "event_id",
                    "contact_id"
                ],
                "properties": {
                    "event_id": {
                        "description": "Unique identifier for this webhook event. Used to guarantee idempotency — duplicate event IDs are rejected.",
                        "type": "string",
                        "example": "evt-abc123"
                    },
                    "contact_id": {
                        "description": "The HubSpot contact ID (client_id) of the contact to update. Must match an existing contact.",
                        "type": "string",
                        "example": "hs-contact-123"
                    },
                    "email": {
                        "description": "New email address. Required if phone is not provided. Must be unique across all contacts.",
                        "type": "string",
                        "format": "email",
                        "example": "updated@example.com",
                        "nullable": true
                    },
                    "phone": {
                        "description": "New phone number. Required if email is not provided. Must match international phone format.",
                        "type": "string",
                        "example": "+1 555 123 4567",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Contacts",
            "description": "Contact management endpoints"
        },
        {
            "name": "Deals",
            "description": "Deal management endpoints"
        },
        {
            "name": "Associations",
            "description": "Contact–Deal association endpoints"
        },
        {
            "name": "Webhooks",
            "description": "HubSpot webhook event receivers"
        }
    ]
}